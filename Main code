const string FILE_NAME = "data.csv";

// 1. INITIALIZE DATABASE: Simply checks if the file exists. If not, creates it with a header row.
void initializeDatabase() {
    ifstream inFile(FILE_NAME);
    if (!inFile) {
        ofstream outFile(FILE_NAME);
        outFile << "ID,Title,Review" << endl; // Write direct CSV column headers
        outFile.close();
    } else {
        inFile.close();
    }
}

// Helper function: Checks if an ID already exists directly inside the data.csv file
bool isIDExisting(string targetID) {
    ifstream file(FILE_NAME);
    string line;
    while (getline(file, line)) {
        if (line.find(targetID + ",") == 0) { // Check if the line starts with our ID followed by a comma
            file.close();
            return true; // Found a duplicate!
        }
    }
    file.close();
    return false; // ID is completely unique
}

// 2. ADD MOVIE: Writes your inputs directly to the bottom of the CSV file immediately
void addMovie() {
    string id, name, review;
    cout << "Enter unique ID (e.g., ID_099): ";
    cin >> id;
    
    // Check the file directly for duplicates before allowing the add
    if (isIDExisting(id)) {
        cout << "Error: This Movie ID already exists in the database file." << endl;
        return;
    }

    cout << "Enter movie name: ";
    cin.ignore();
    getline(cin, name);
    cout << "Enter movie review: ";
    getline(cin, review);

    // Open file in Append mode ("ios::app") to glue data to the absolute bottom
    ofstream outFile(FILE_NAME, ios::app);
    if (outFile.is_open()) {
        outFile << id << "," << name << "," << review << endl;
        outFile.close();
        cout << "Movie added directly to data.csv successfully." << endl;
    } else {
        cout << "Error: Could not open database file for writing." << endl;
    }
}

// 3. SHOW ALL RECORDS: Streams and displays rows directly from the text file row-by-row
void showAll() {
    ifstream inFile(FILE_NAME);
    if (!inFile) {
        cout << "No records available (Database file missing)." << endl;
        return;
    }

    string header, line;
    getline(inFile, header); // Read and skip the header row (ID,Title,Review)

    int count = 0;
    while (getline(inFile, line)) {
        // Parse the comma-separated line into pieces
        size_t firstComma = line.find(',');
        size_t secondComma = line.find(',', firstComma + 1);

        if (firstComma != string::npos && secondComma != string::npos) {
            string id = line.substr(0, firstComma);
            string name = line.substr(firstComma + 1, secondComma - firstComma - 1);
            string review = line.substr(secondComma + 1);

            cout << "\n-----------------------------" << endl;
            cout << "ID:     " << id << endl;
            cout << "Name:   " << name << endl;
            cout << "Review: " << review << endl;
            count++;
        }
    }
    inFile.close();

    if (count == 0) {
        cout << "Database file is empty." << endl;
    } else {
        cout << "-----------------------------\nTotal Records Found: " << count << endl;
    }
}

// 4. SECURE HARDWARE SEARCH: Triggered by option 3, gets key from ESP32, searches CSV sequentially
void searchDatabaseWithHardware() {
    // Open communication port line to talk to ESP32 (Change "COM3" to match your Arduino IDE port!)
    HANDLE hSerial = CreateFile("\\\\.\\COM3", GENERIC_READ | GENERIC_WRITE, 0, NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);

    if (hSerial == INVALID_HANDLE_VALUE) {
        cout << "Error opening serial port! Ensure ESP32 is plugged in and check COM port." << endl;
        return;
    }

    // Set configuration parameters to match your project's 115200 standard speed
    DCB dcbSerialParams = { 0 };
    dcbSerialParams.DCBlength = sizeof(dcbSerialParams);
    GetCommState(hSerial, &dcbSerialParams);
    dcbSerialParams.BaudRate = CBR_115200;
    dcbSerialParams.ByteSize = 8;
    dcbSerialParams.StopBits = ONESTOPBIT;
    dcbSerialParams.Parity = NOPARITY;
    SetCommState(hSerial, &dcbSerialParams);

    // Send "SEND_KEY\n" command down the wire to trigger the ESP32
    DWORD bytesWritten;
    string command = "SEND_KEY\n";
    WriteFile(hSerial, command.c_str(), command.length(), &bytesWritten, NULL);

    cout << "Trigger sent. Awaiting validation key from ESP32..." << endl;
    Sleep(500); // Give the wire a split second to send characters over

    // Buffer array to catch incoming transmission data characters
    char szBuff[20] = { 0 };
    DWORD bytesRead;
    
    if (ReadFile(hSerial, szBuff, 19, &bytesRead, NULL)) {
        string targetID = "";
        // Clean out and isolate text data safely, removing hidden format characters (\r or \n)
        for (int i = 0; i < (int)bytesRead; i++) {
            if (szBuff[i] != '\r' && szBuff[i] != '\n') {
                targetID += szBuff[i];
            }
        }

        cout << "Hardware Verified Token Key Received: [" << targetID << "]" << endl;

        // >>> YOUR PROFESSOR'S EXACT SEQUENTIAL CSV FILE SEARCH CODE SITS HERE <<<
        ifstream file(FILE_NAME);
        string line;
        bool found = false;

        while (getline(file, line)) {
            if (line.find(targetID) == 0) { // Sequential check for matching ID
                cout << "\n>>> Data Retrieved: " << line << endl;
                found = true;
                break;
            }
        }
        file.close();

        if (!found) {
            cout << "No matching records found in data.csv for this secure key token." << endl;
        }
    }

    CloseHandle(hSerial); // Hang up connection port safely
}

// 5. UPDATE MOVIE REVIEW: Uses the temporary file scratchpad logic taught in your slides!
void updateReview() {
    string targetID;
    cout << "Enter Movie ID to update review: ";
    cin >> targetID;

    if (!isIDExisting(targetID)) {
        cout << "ID Not Found inside the database!" << endl;
        return;
    }

    // Setting up our two file pointers to process data sequentially
    ifstream inFile(FILE_NAME);
    ofstream tempFile("temp.csv"); // Temporary file scratchpad

    string line;
    bool updated = false;

    // Copy row headers straight over
    getline(inFile, line);
    tempFile << line << endl;

    // Process file rows sequentially line-by-line
    while (getline(inFile, line)) {
        if (line.find(targetID + ",") == 0) { // Found the row to change!
            size_t firstComma = line.find(',');
            size_t secondComma = line.find(',', firstComma + 1);
            string name = line.substr(firstComma + 1, secondComma - firstComma - 1);

            cout << "Updating review for: " << name << endl;
            cout << "Enter updated review text: ";
            string newReview;
            cin.ignore();
            getline(cin, newReview);

            // Write the new modified row down to our temporary file scratchpad instead of the old one
            tempFile << targetID << "," << name << "," << newReview << endl;
            updated = true;
        } else {
            // Keep original row untouched and pass it straight through to temp.csv
            tempFile << line << endl;
        }
    }

    inFile.close();
    tempFile.close();

    // Final file swap sequence to overwrite old data
    remove(FILE_NAME.c_str());             // Delete old data.csv
    rename("temp.csv", FILE_NAME.c_str()); // Rename temp.csv to data.csv

    if (updated) cout << "Review has been updated and saved successfully!" << endl;
}

