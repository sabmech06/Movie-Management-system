    initializeDatabase(); // Make sure data.csv is safely created or opened on launch
    while (true) {
        showMenu();
        int choice;
        cin >> choice;
        if (choice == 1) addMovie();
        else if (choice == 2) showAll();
        else if (choice == 3) searchDatabaseWithHardware(); // Launch hardware loop
        else if (choice == 4) updateReview();
        else if (choice == 5) {
            cout << "Exiting system application." << endl;
            break;
        } else {
            cout << "Invalid menu input selected." << endl;
        }
        cout << endl;
    }
    return 0;
}
